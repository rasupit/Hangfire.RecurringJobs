@inject Microsoft.Extensions.Options.IOptions<Hangfire.Extension.RecurringJobsOptions> HangfireOptions
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hangfire Extension</title>
    @if (HangfireOptions.Value.UseEmbeddedStyles)
    {
        <style>
@Html.Raw(Hangfire.Extension.Services.RecurringJobsStyleProvider.GetStyles())
        </style>
    }
    else
    {
        <link rel="stylesheet" href="@HangfireOptions.Value.StylesPath" />
    }
</head>
<body>
    <div class="hfext-shell min-vh-100">
        <header class="navbar navbar-expand border-bottom bg-body">
            <div class="container-xl">
                <a class="navbar-brand fw-semibold" href="@HangfireOptions.Value.RoutePrefixNormalized">Hangfire.Extension</a>
                <nav class="navbar-nav">
                    <a class="nav-link active" aria-current="page" href="@HangfireOptions.Value.RoutePrefixNormalized">Recurring jobs</a>
                </nav>
            </div>
        </header>
        <main class="container-xl py-4 py-lg-5">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
