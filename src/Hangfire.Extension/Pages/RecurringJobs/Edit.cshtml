@page "{id}"
@model Hangfire.Extension.Pages.RecurringJobs.EditModel
@inject Microsoft.Extensions.Options.IOptions<Hangfire.Extension.RecurringJobsOptions> HangfireOptions
@{
    ViewData["Title"] = "Edit cron";
}

<section class="d-grid gap-4 hfext-page-narrow"
         data-hfext-cron-preview-url="@($"{HangfireOptions.Value.ApiRoutePrefix}/preview")">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
        <div>
            <p class="text-uppercase text-primary fw-semibold small mb-2">Recurring job</p>
            <h1 class="display-6 mb-2">Edit cron</h1>
            <p class="lead mb-1">@Model.Id</p>
            <p class="text-body-secondary mb-1">@Model.JobType</p>
            <p class="text-body-secondary mb-0">@Model.MethodName</p>
        </div>
        <a asp-page="./Index" class="btn btn-outline-secondary">Back to Recurring Jobs</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <div class="d-grid gap-2 mb-4">
                <span class="badge text-bg-secondary align-self-start">Cron schedule</span>
                <p class="text-body-secondary mb-0">Update the expression carefully. The new value is applied to the existing recurring job definition.</p>
            </div>
            <form method="post"
                  class="d-grid gap-3"
                  data-hfext-cron-editor
                  data-hfext-cron-preview-url="@($"{HangfireOptions.Value.ApiRoutePrefix}/preview")">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input asp-for="Id" type="hidden" />
                <div>
                    <label asp-for="CronExpression" class="form-label"></label>
                    <input asp-for="CronExpression" class="form-control" data-hfext-cron-input />
                    <span asp-validation-for="CronExpression" class="text-danger small"></span>
                </div>
                @if (Model.IsDisabled)
                {
                    <p class="small text-body-secondary mb-0">
                        Saving a disabled job will apply the new schedule and enable it again.
                    </p>
                }
                <div class="hfext-cron-preview" data-hfext-cron-preview>
                    <p class="hfext-cron-summary mb-1" data-hfext-cron-summary>@Model.CronPreview.Summary</p>
                    @if (!string.IsNullOrWhiteSpace(Model.CronPreview.Description))
                    {
                        <p class="text-body-secondary mb-0" data-hfext-cron-description>@Model.CronPreview.Description</p>
                    }
                    else
                    {
                        <p class="text-body-secondary mb-0" data-hfext-cron-description hidden></p>
                    }
                    @if (Model.CronPreview.UpcomingOccurrences.Count > 0)
                    {
                        <div data-hfext-cron-occurrences-wrapper>
                            <p class="small text-body-secondary mb-1">Upcoming runs</p>
                            <ul class="hfext-cron-occurrences mb-0" data-hfext-cron-occurrences>
                                @foreach (var occurrence in Model.CronPreview.UpcomingOccurrences)
                                {
                                    <li>@occurrence</li>
                                }
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div data-hfext-cron-occurrences-wrapper hidden>
                            <p class="small text-body-secondary mb-1">Upcoming runs</p>
                            <ul class="hfext-cron-occurrences mb-0" data-hfext-cron-occurrences></ul>
                        </div>
                    }
                </div>
                <div class="d-flex flex-wrap justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        @Html.Raw(Hangfire.Extension.Services.RecurringJobsScriptProvider.GetScript())
    </script>
}
