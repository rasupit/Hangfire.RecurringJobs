<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hangfire.Extension.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hangfire.Extension.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-chrome">
        <header class="topbar">
            <div class="topbar-inner">
                <a class="brand" asp-area="" asp-page="/Index">Hangfire.Extension</a>
                <nav class="nav-links">
                    <a asp-area="" asp-page="/Index">Overview</a>
                    <a asp-area="" asp-page="/RecurringJobs/Index">Recurring jobs</a>
                </nav>
            </div>
        </header>
        <main role="main" class="main-shell">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
